<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Contact Research</title>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f9fafb; color: #111827; }
.topnav { display:flex; align-items:center; justify-content:space-between; padding:0 24px; height:52px; background:#fff; border-bottom:1px solid #e5e7eb; position:sticky; top:0; z-index:100; }
.topnav-brand { font-size:16px; font-weight:700; }
.page { max-width:1100px; margin:0 auto; padding:24px; }
.section { background:#fff; border-radius:8px; border:1px solid #e5e7eb; margin-bottom:20px; padding:20px; }
.section h2 { font-size:15px; font-weight:600; margin-bottom:4px; }
.section .hint { font-size:13px; color:#6b7280; margin-bottom:16px; }
.badge { display:inline-block; padding:2px 8px; border-radius:12px; font-size:11px; font-weight:600; }
.badge-hot { background:#fef2f2; color:#dc2626; }
.badge-warm { background:#fff7ed; color:#ea580c; }
.badge-cold { background:#f0f9ff; color:#0284c7; }
.badge-new { background:#f0fdf4; color:#16a34a; }
.badge-pending { background:#fefce8; color:#d97706; }
.badge-confirmed { background:#f0fdf4; color:#16a34a; }
.badge-attio { background:#ede9fe; color:#7c3aed; }
table { width:100%; border-collapse:collapse; font-size:13px; }
th { text-align:left; padding:8px 10px; background:#f9fafb; border-bottom:1px solid #e5e7eb; font-weight:600; color:#6b7280; font-size:11px; text-transform:uppercase; }
td { padding:8px 10px; border-bottom:1px solid #f3f4f6; vertical-align:top; }
.btn { padding:6px 14px; border-radius:6px; font-size:13px; font-weight:500; cursor:pointer; border:none; }
.btn-primary { background:#1d4ed8; color:#fff; }
.btn-primary:hover { background:#1e40af; }
.btn-secondary { background:#f3f4f6; color:#374151; border:1px solid #d1d5db; }
.btn-sm { padding:3px 10px; font-size:12px; border-radius:4px; }
.btn-green { background:#16a34a; color:#fff; }
.btn-red { background:#fff; color:#dc2626; border:1px solid #fca5a5; }
.btn-purple { background:#7c3aed; color:#fff; }
input[type=text], input[type=url], select, textarea { width:100%; border:1px solid #d1d5db; border-radius:6px; padding:7px 10px; font-size:13px; font-family:inherit; }
input:focus, select:focus, textarea:focus { outline:none; border-color:#1d4ed8; box-shadow:0 0 0 2px rgba(29,78,216,.15); }
label { display:block; font-size:12px; font-weight:600; color:#374151; margin-bottom:4px; margin-top:12px; }
.form-grid { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
.accordion-body { display:none; padding-top:12px; border-top:1px solid #f3f4f6; margin-top:12px; }
.accordion-body.open { display:block; }
.row-actions { display:flex; gap:6px; flex-wrap:wrap; }
.attio-found { background:#ede9fe; border-radius:4px; padding:4px 8px; font-size:12px; color:#7c3aed; }
.tabs { display:flex; gap:0; border-bottom:2px solid #e5e7eb; margin-bottom:20px; }
.tab { padding:8px 18px; font-size:14px; font-weight:500; color:#6b7280; cursor:pointer; border-bottom:2px solid transparent; margin-bottom:-2px; }
.tab.active { color:#1d4ed8; border-bottom-color:#1d4ed8; }
.filter-bar { display:flex; gap:8px; align-items:center; margin-bottom:16px; flex-wrap:wrap; }
.filter-bar select, .filter-bar input { width:auto; }
.empty { color:#9ca3af; font-size:13px; padding:24px; text-align:center; }
.batch-toolbar { position:sticky; top:52px; z-index:90; background:#1e293b; color:#fff; padding:10px 16px; border-radius:8px 8px 0 0; display:none; align-items:center; gap:12px; font-size:13px; }
.batch-toolbar.visible { display:flex; }
.batch-toolbar .count { font-weight:700; }
.batch-toolbar .btn { font-size:12px; }
.batch-toolbar .btn-step { background:#3b82f6; color:#fff; border:none; padding:5px 12px; border-radius:4px; cursor:pointer; font-weight:500; }
.batch-toolbar .btn-step:hover { background:#2563eb; }
.batch-toolbar .btn-step:disabled { opacity:.5; cursor:not-allowed; }
.batch-toolbar .btn-clear { background:transparent; color:#94a3b8; border:1px solid #475569; padding:4px 10px; border-radius:4px; cursor:pointer; }
.batch-progress { font-size:12px; color:#94a3b8; margin-left:auto; }
.badge-identified { background:#dbeafe; color:#1d4ed8; }
.badge-enriched { background:#fef3c7; color:#d97706; }
.badge-error { background:#fef2f2; color:#dc2626; }
input[type=checkbox] { width:16px; height:16px; cursor:pointer; accent-color:#3b82f6; }
</style>
</head>
<body>

<nav class="topnav">
  <span class="topnav-brand">Contact Research</span>
</nav>

<div class="page">

  <!-- TAB NAV -->
  <div class="tabs">
    <div class="tab active" onclick="showTab('library',this)">Research Library</div>
    <div class="tab" onclick="showTab('finder',this)">Find Contact</div>
    <div class="tab" onclick="showTab('queue',this)">Contact Queue</div>
    <div class="tab" onclick="showTab('export',this)">Export / Import</div>
  </div>

  <!-- TAB: RESEARCH LIBRARY -->
  <div id="tab-library">
    <div id="batch-toolbar" class="batch-toolbar">
      <span class="count"><span id="batch-count">0</span> selected</span>
      <button class="btn btn-step" onclick="runBatchStep('identify')" id="btn-batch-identify">1. Identify contacts</button>
      <button class="btn btn-step" onclick="runBatchStep('enrich')" id="btn-batch-enrich">2. Enrich emails</button>
      <button class="btn btn-step" onclick="runBatchStep('confirm')" id="btn-batch-confirm">3. Confirm all</button>
      <span class="batch-progress" id="batch-progress"></span>
      <button class="btn btn-clear" onclick="clearSelection()">Clear</button>
    </div>
    <div class="section" style="border-radius:0 0 8px 8px">
      <h2>Research Library</h2>
      <p class="hint">Select rows for batch contact pipeline. Steps: Identify &rarr; Enrich &rarr; Confirm.</p>
      <div id="library-list"><div class="empty">Loading...</div></div>
    </div>
  </div>

  <!-- TAB: FIND CONTACT -->
  <div id="tab-finder" style="display:none">
    <div class="section">
      <h2>Find Contact</h2>
      <p class="hint">Identify the right person at a target company. Checks Attio first before external enrichment.</p>
      <div id="attio-check-result"></div>
      <div class="form-grid">
        <div>
          <label>Company Name *</label>
          <input type="text" id="fc-company" placeholder="e.g. Verdane" oninput="debounceAttioCheck()">
        </div>
        <div>
          <label>Contact Role Required</label>
          <select id="fc-role">
            <option value="founder_ceo">Founder / CEO</option>
            <option value="operating_partner">Operating Partner</option>
            <option value="talent_partner">Talent Partner</option>
            <option value="gp">General Partner / Managing Partner</option>
            <option value="portfolio_contact">Portfolio Company -- CPO/COO</option>
          </select>
        </div>
      </div>
      <div id="portfolio-fields" style="display:none">
        <div class="form-grid">
          <div>
            <label>Fund Name</label>
            <input type="text" id="fc-fund" placeholder="e.g. Verdane Capital">
          </div>
          <div>
            <label>GP Name (if known)</label>
            <input type="text" id="fc-gp" placeholder="Leave blank to find">
          </div>
        </div>
        <div>
          <label>Operating Partner at Fund (if known)</label>
          <input type="text" id="fc-op" placeholder="Leave blank to find">
        </div>
      </div>
      <div>
        <label>LinkedIn URL (optional -- skips web search)</label>
        <input type="url" id="fc-linkedin" placeholder="https://linkedin.com/in/...">
      </div>
      <div>
        <label>Company Domain (for email enrichment — e.g. verdane.com)</label>
        <input type="text" id="fc-domain" placeholder="e.g. verdane.com">
        <div style="font-size:11px;color:#9ca3af;margin-top:4px">Only needed if LinkedIn URL is not available</div>
      </div>
      <div id="salesnav-section" style="margin-top:16px">
        <label>Sales Navigator Search</label>
        <div style="display:flex;gap:8px;align-items:center">
          <a id="salesnav-link" href="#" target="_blank" class="btn btn-secondary btn-sm" onclick="return openSalesNav()">
            Open Sales Navigator search
          </a>
          <input type="url" id="fc-salesnav" placeholder="Paste Sales Navigator URL after finding person" style="flex:1">
        </div>
        <div style="font-size:11px;color:#9ca3af;margin-top:4px">Click the link to open a pre-built search, then paste the person's Sales Navigator URL above.</div>
      </div>
      <div style="margin-top:16px;display:flex;gap:8px">
        <button class="btn btn-primary" onclick="findContact()">Find Contact via Web Search</button>
        <button class="btn btn-secondary" onclick="addManualContact()">Add Manually</button>
      </div>
      <div id="finder-result" style="margin-top:16px"></div>
    </div>
  </div>

  <!-- TAB: CONTACT QUEUE -->
  <div id="tab-queue" style="display:none">
    <div class="section">
      <h2>Contact Queue</h2>
      <div class="filter-bar">
        <select id="q-filter" onchange="loadQueue()">
          <option value="">All</option>
          <option value="pending">Pending</option>
          <option value="confirmed">Confirmed</option>
          <option value="dismissed">Dismissed</option>
        </select>
        <button class="btn btn-secondary btn-sm" onclick="loadQueue()">Refresh</button>
      </div>
      <div id="queue-list"><div class="empty">Loading...</div></div>
    </div>
  </div>

  <!-- TAB: EXPORT / IMPORT -->
  <div id="tab-export" style="display:none">
    <div class="section">
      <h2>Closely Export</h2>
      <p class="hint">Download CSV of contacts with Sales Navigator URLs. Upload to Closely to get LinkedIn URLs.</p>
      <p style="font-size:12px;color:#6b7280;margin-bottom:12px">Required columns: First Name, Last Name, LinkedIn or SalesNavigator Profile URL</p>
      <a href="/api/closely-export" class="btn btn-primary btn-sm" download>Download Closely CSV</a>
      <div style="margin-top:20px">
        <label>Import Closely result (paste CSV text or upload)</label>
        <textarea id="closely-import-text" rows="6" placeholder="Paste Closely output CSV here..."></textarea>
        <button class="btn btn-secondary btn-sm" onclick="importClosely()" style="margin-top:8px">Import LinkedIn URLs</button>
        <span id="closely-import-status" style="font-size:12px;margin-left:10px;color:#6b7280"></span>
      </div>
    </div>
    <div class="section">
      <h2>FullEnrich Export</h2>
      <p class="hint">Download contacts with LinkedIn URLs but no email yet. Upload to FullEnrich to get email addresses.</p>
      <a href="/api/fullenrich-export" class="btn btn-primary btn-sm" download>Download FullEnrich CSV</a>
      <div style="margin-top:20px">
        <label>Import FullEnrich result (paste CSV text)</label>
        <textarea id="fe-import-text" rows="6" placeholder="Paste FullEnrich output CSV here..."></textarea>
        <button class="btn btn-secondary btn-sm" onclick="importFullEnrich()" style="margin-top:8px">Import Emails</button>
        <span id="fe-import-status" style="font-size:12px;margin-left:10px;color:#6b7280"></span>
      </div>
    </div>
  </div>

</div>

<script>
let _attioTimer;

function showTab(name, el) {
  document.querySelectorAll('[id^=tab-]').forEach(t => t.style.display='none');
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.getElementById('tab-' + name).style.display = '';
  el.classList.add('active');
  if (name === 'library') loadLibrary();
  if (name === 'queue') loadQueue();
}

// ===== RESEARCH LIBRARY =====
let selectedRows = new Map(); // id -> { company, contextType, status }

async function loadLibrary() {
  const el = document.getElementById('library-list');
  el.innerHTML = '<div class="empty">Loading research...</div>';
  try {
    const r = await fetch('/api/research-library');
    const items = await r.json();
    if (!items.length) { el.innerHTML = '<div class="empty">No research done yet. Use the Research Hub to research companies.</div>'; return; }

    // Also fetch contacts to know pipeline status per company
    let contactsByCompany = {};
    try {
      const cr = await fetch('/api/contacts');
      const allContacts = await cr.json();
      allContacts.forEach(c => {
        if (c.company) contactsByCompany[c.company.toLowerCase()] = c;
      });
    } catch(e) {}

    el.innerHTML = '<table><thead><tr>' +
      '<th style="width:36px"><input type="checkbox" id="select-all" onchange="toggleAll(this.checked)"></th>' +
      '<th>Company</th><th>Type</th><th>Date</th><th>Score</th><th>Contact Status</th><th>Actions</th>' +
      '</tr></thead><tbody>' +
      items.map(item => {
        const score = item.score;
        const badgeClass = score ? (score.overall_badge === 'Hot' ? 'badge-hot' : score.overall_badge === 'Warm' ? 'badge-warm' : 'badge-cold') : '';
        const companyKey = (item.company_name || '').toLowerCase();
        const contact = contactsByCompany[companyKey];
        const contactStatus = contact ? contact.status : 'pending';
        const hasEmail = contact && contact.email;
        const hasName = contact && contact.name;
        const statusBadge = getContactStatusBadge(contactStatus, hasName, hasEmail);
        const rowId = item.id || item.company_name;
        const isChecked = selectedRows.has(rowId);

        return '<tr data-row-id="' + rowId + '" data-company="' + (item.company_name||'').replace(/"/g,'&quot;') + '" data-context="' + (item.context_type||'') + '" data-contact-id="' + (contact ? contact.id : '') + '">' +
          '<td><input type="checkbox" ' + (isChecked ? 'checked' : '') + ' onchange="toggleRow(\'' + rowId + '\', this.checked, this.closest(\'tr\'))"></td>' +
          '<td><strong>' + (item.company_name || '\u2014') + '</strong></td>' +
          '<td style="color:#6b7280">' + (item.context_type || '\u2014') + '</td>' +
          '<td style="color:#6b7280">' + (item.created_at ? item.created_at.substring(0,10) : '\u2014') + '</td>' +
          '<td>' + (score ? '<span class="badge ' + badgeClass + '">' + score.overall_badge + ' ' + Math.round((score.final_score||0)*100) + '</span>' : '<span style="color:#9ca3af;font-size:12px">not scored</span>') + '</td>' +
          '<td id="status-' + rowId + '">' + statusBadge + '</td>' +
          '<td><button class="btn btn-primary btn-sm" onclick="selectForContact(\'' + (item.company_name||'').replace(/'/g, "\\'") + '\', \'' + (item.context_type||'') + '\')">Find Contact &rarr;</button></td>' +
          '</tr>';
      }).join('') + '</tbody></table>';
    updateToolbar();
  } catch(e) {
    el.innerHTML = '<div class="empty">Error: ' + e.message + '</div>';
  }
}

function getContactStatusBadge(status, hasName, hasEmail) {
  if (status === 'confirmed') return '<span class="badge badge-confirmed">confirmed</span>';
  if (status === 'dismissed') return '<span class="badge" style="background:#f3f4f6;color:#6b7280">dismissed</span>';
  if (status === 'error') return '<span class="badge badge-error">error</span>';
  if (hasEmail) return '<span class="badge badge-enriched">enriched</span>';
  if (hasName) return '<span class="badge badge-identified">identified</span>';
  return '<span class="badge badge-pending">pending</span>';
}

function toggleRow(rowId, checked, trEl) {
  if (checked) {
    selectedRows.set(rowId, {
      company: trEl.dataset.company,
      contextType: trEl.dataset.context,
      contactId: trEl.dataset.contactId
    });
  } else {
    selectedRows.delete(rowId);
  }
  updateToolbar();
}

function toggleAll(checked) {
  document.querySelectorAll('#library-list tbody tr').forEach(tr => {
    const rowId = tr.dataset.rowId;
    const cb = tr.querySelector('input[type=checkbox]');
    if (cb) cb.checked = checked;
    if (checked) {
      selectedRows.set(rowId, {
        company: tr.dataset.company,
        contextType: tr.dataset.context,
        contactId: tr.dataset.contactId
      });
    } else {
      selectedRows.delete(rowId);
    }
  });
  updateToolbar();
}

function clearSelection() {
  selectedRows.clear();
  document.querySelectorAll('#library-list input[type=checkbox]').forEach(cb => cb.checked = false);
  document.getElementById('select-all').checked = false;
  updateToolbar();
}

function updateToolbar() {
  const toolbar = document.getElementById('batch-toolbar');
  const countEl = document.getElementById('batch-count');
  const n = selectedRows.size;
  countEl.textContent = n;
  if (n > 0) {
    toolbar.classList.add('visible');
  } else {
    toolbar.classList.remove('visible');
  }
  document.getElementById('batch-progress').textContent = '';
}

async function runBatchStep(step) {
  const progressEl = document.getElementById('batch-progress');
  const entries = Array.from(selectedRows.entries());
  const total = entries.length;
  if (!total) return;

  // Disable buttons during run
  document.querySelectorAll('.btn-step').forEach(b => b.disabled = true);
  let done = 0, errors = 0;

  for (const [rowId, info] of entries) {
    progressEl.textContent = (done+1) + '/' + total + ' processing...';
    const statusEl = document.getElementById('status-' + rowId);
    try {
      if (step === 'identify') {
        // Call research pipeline (identify + enrich in one call)
        const roleMap = { 'pe_vc': 'operating_partner', 'exec_search': 'gp', 'portfolio': 'portfolio_contact' };
        const role = roleMap[info.contextType] || 'operating_partner';
        const r = await fetch('/api/research', {
          method: 'POST',
          headers: {'Content-Type':'application/json'},
          body: JSON.stringify({ companyName: info.company, campaignType: role })
        });
        const d = await r.json();
        if (d.error) throw new Error(d.error);
        // Update the contact ID in our selection
        info.contactId = d.id;
        // Update the row's data attribute
        const tr = document.querySelector('tr[data-row-id="' + rowId + '"]');
        if (tr) tr.dataset.contactId = d.id;
        if (statusEl) statusEl.innerHTML = getContactStatusBadge('pending', d.name, d.email);
      } else if (step === 'enrich') {
        if (!info.contactId) { if (statusEl) statusEl.innerHTML = '<span class="badge badge-error">no contact</span>'; errors++; done++; continue; }
        const r = await fetch('/api/contacts/' + info.contactId + '/enrich', { method: 'POST' });
        const d = await r.json();
        if (d.error) throw new Error(d.error);
        if (statusEl) statusEl.innerHTML = getContactStatusBadge('pending', true, d.email);
      } else if (step === 'confirm') {
        if (!info.contactId) { if (statusEl) statusEl.innerHTML = '<span class="badge badge-error">no contact</span>'; errors++; done++; continue; }
        await fetch('/api/contacts/' + info.contactId + '/confirm', { method: 'POST' });
        if (statusEl) statusEl.innerHTML = getContactStatusBadge('confirmed', true, true);
      }
    } catch(e) {
      errors++;
      if (statusEl) statusEl.innerHTML = '<span class="badge badge-error">error</span>';
      console.error('Batch ' + step + ' error for ' + info.company + ':', e.message);
    }
    done++;
    // 400ms pause between API calls
    if (done < total) await new Promise(ok => setTimeout(ok, 400));
  }
  progressEl.textContent = done + '/' + total + ' done' + (errors ? ' (' + errors + ' errors)' : '');
  document.querySelectorAll('.btn-step').forEach(b => b.disabled = false);
  // Refresh library after a moment
  setTimeout(() => loadLibrary(), 1000);
}

function selectForContact(company, contextType) {
  showTab('finder', document.querySelectorAll('.tab')[1]);
  document.getElementById('fc-company').value = company;
  var roleMap = { 'pe_vc': 'operating_partner', 'exec_search': 'gp', 'portfolio': 'portfolio_contact' };
  var role = roleMap[contextType] || 'operating_partner';
  document.getElementById('fc-role').value = role;
  document.getElementById('fc-role').dispatchEvent(new Event('change'));
  debounceAttioCheck();
  updateSalesNavLink();
}

// ===== ATTIO PRE-CHECK =====
function debounceAttioCheck() {
  clearTimeout(_attioTimer);
  _attioTimer = setTimeout(checkAttio, 800);
}

async function checkAttio() {
  var company = document.getElementById('fc-company').value.trim();
  var el = document.getElementById('attio-check-result');
  if (!company) { el.innerHTML = ''; return; }
  el.innerHTML = '<div style="font-size:12px;color:#6b7280">Checking Attio...</div>';
  try {
    var r = await fetch('/api/attio-check?name=' + encodeURIComponent(company));
    var d = await r.json();
    if (d.found) {
      el.innerHTML = '<div class="attio-found">Found ' + d.count + ' contact(s) already in Attio for ' + company + ': ' +
        d.records.map(function(r) { return (r.name||'?') + (r.status ? ' [' + r.status + ']' : ''); }).join(', ') +
        ' \u2014 confirm before enriching</div>';
    } else {
      el.innerHTML = '<div style="font-size:12px;color:#16a34a;padding:4px 0">Not in Attio \u2014 proceed with contact research</div>';
    }
  } catch(e) { el.innerHTML = ''; }
}

// ===== PORTFOLIO FIELDS TOGGLE =====
document.getElementById('fc-role').addEventListener('change', function() {
  var isPortfolio = this.value === 'portfolio_contact';
  document.getElementById('portfolio-fields').style.display = isPortfolio ? '' : 'none';
  updateSalesNavLink();
});

// ===== SALES NAV URL =====
function updateSalesNavLink() {
  var company = document.getElementById('fc-company').value.trim();
  var role = document.getElementById('fc-role').value;
  if (!company) return;
  fetch('/api/salesnav-url?company=' + encodeURIComponent(company) + '&role=' + role)
    .then(function(r) { return r.json(); })
    .then(function(d) { document.getElementById('salesnav-link').href = d.url; });
}

function openSalesNav() {
  updateSalesNavLink();
  var link = document.getElementById('salesnav-link');
  if (link.href === '#' || link.href === window.location.href + '#') {
    alert('Enter a company name first');
    return false;
  }
  return true;
}

document.getElementById('fc-company').addEventListener('input', updateSalesNavLink);

// ===== FIND CONTACT =====
async function findContact() {
  var company = document.getElementById('fc-company').value.trim();
  if (!company) { alert('Company name required'); return; }
  var role = document.getElementById('fc-role').value;
  var linkedin = document.getElementById('fc-linkedin').value.trim();
  var companyDomain = document.getElementById('fc-domain').value.trim();
  var salesNav = document.getElementById('fc-salesnav').value.trim();
  var fundEl = document.getElementById('fc-fund');
  var gpEl = document.getElementById('fc-gp');
  var opEl = document.getElementById('fc-op');
  var fundName = fundEl ? fundEl.value.trim() : '';
  var gpName = gpEl ? gpEl.value.trim() : '';
  var opPartner = opEl ? opEl.value.trim() : '';

  var el = document.getElementById('finder-result');
  el.innerHTML = '<div style="color:#6b7280;font-size:13px">Searching...</div>';

  try {
    var contextParts = [];
    if (fundName) contextParts.push('Fund: ' + fundName);
    if (gpName) contextParts.push('GP: ' + gpName);
    if (opPartner) contextParts.push('OP: ' + opPartner);

    var r = await fetch('/api/research', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({
        companyName: company, campaignType: role,
        linkedinUrl: linkedin || salesNav || undefined,
        context: contextParts.length ? contextParts.join(', ') : undefined,
        companyDomain: companyDomain || undefined
      })
    });
    var d = await r.json();
    if (d.error) { el.innerHTML = '<div style="color:#dc2626">' + d.error + '</div>'; return; }

    // If Sales Nav URL provided, save it
    if (salesNav && d.id) {
      await fetch('/api/contacts/' + d.id + '/salesnav', {
        method: 'PATCH', headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ salesNavUrl: salesNav })
      });
    }

    el.innerHTML = '<div style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:6px;padding:12px;font-size:13px">' +
      '<strong>' + (d.name || 'Contact found') + '</strong> \u2014 ' + (d.title || '') + ' at ' + (d.company || company) + '<br>' +
      (d.email ? 'Email: ' + d.email + '<br>' : '') +
      (d.linkedinUrl || salesNav ? 'LinkedIn: ' + (d.linkedinUrl || salesNav) + '<br>' : '') +
      '<div style="margin-top:8px;display:flex;gap:8px">' +
        '<button class="btn btn-green btn-sm" onclick="confirmContact(\'' + (d.id||'') + '\')">Confirm</button>' +
        '<button class="btn btn-red btn-sm" onclick="dismissContact(\'' + (d.id||'') + '\')">Dismiss</button>' +
      '</div></div>';
  } catch(e) {
    el.innerHTML = '<div style="color:#dc2626">Error: ' + e.message + '</div>';
  }
}

async function addManualContact() {
  var company = document.getElementById('fc-company').value.trim();
  var role = document.getElementById('fc-role').value;
  var salesNav = document.getElementById('fc-salesnav').value.trim();
  if (!company) { alert('Company name required'); return; }

  var name = prompt('Contact full name (First Last):');
  if (!name) return;

  var r = await fetch('/api/research', {
    method: 'POST', headers: {'Content-Type':'application/json'},
    body: JSON.stringify({ companyName: company, campaignType: role, linkedinUrl: salesNav || undefined })
  });
  var d = await r.json();
  document.getElementById('finder-result').innerHTML = '<div style="color:#16a34a;font-size:13px">Contact added to queue</div>';
}

async function confirmContact(id) {
  if (!id) return;
  await fetch('/api/contacts/' + id + '/confirm', { method: 'POST' });
  document.getElementById('finder-result').innerHTML = '<div style="color:#16a34a;font-size:13px">Confirmed \u2014 ready for Outreach Drafter</div>';
}

async function dismissContact(id) {
  if (!id) return;
  await fetch('/api/contacts/' + id + '/dismiss', { method: 'POST' });
  document.getElementById('finder-result').innerHTML = '<div style="color:#6b7280;font-size:13px">Dismissed</div>';
}

// ===== CONTACT QUEUE =====
async function loadQueue() {
  var status = document.getElementById('q-filter').value;
  var el = document.getElementById('queue-list');
  var url = status ? '/api/contacts?status=' + status : '/api/contacts';
  try {
    var r = await fetch(url);
    var contacts = await r.json();
    if (!contacts.length) { el.innerHTML = '<div class="empty">No contacts in queue.</div>'; return; }
    el.innerHTML = '<table><thead><tr><th>Name</th><th>Company</th><th>Role</th><th>Email</th><th>LinkedIn</th><th>Sales Nav</th><th>Status</th><th>Actions</th></tr></thead><tbody>' +
      contacts.map(function(c) {
        return '<tr>' +
        '<td>' + (c.name || '\u2014') + '</td>' +
        '<td>' + (c.company || '\u2014') + '</td>' +
        '<td style="font-size:12px;color:#6b7280">' + (c.title || c.campaign_type || '\u2014') + '</td>' +
        '<td style="font-size:12px">' + (c.email || '\u2014') + '</td>' +
        '<td style="font-size:12px">' + (c.linkedin_url ? '<a href="' + c.linkedin_url + '" target="_blank">Link</a>' : '\u2014') + '</td>' +
        '<td>' +
          (c.sales_nav_url ? '<a href="' + c.sales_nav_url + '" target="_blank" style="font-size:11px">Sales Nav</a>' : '') +
          '<input type="url" placeholder="Paste Sales Nav URL" style="width:160px;font-size:11px;padding:3px 6px;margin-top:2px" onblur="saveSalesNav(\'' + c.id + '\', this.value)" value="' + (c.sales_nav_url||'') + '">' +
        '</td>' +
        '<td><span class="badge badge-' + (c.status||'pending') + '">' + (c.status||'pending') + '</span></td>' +
        '<td class="row-actions">' +
          (c.status !== 'confirmed' ? '<button class="btn btn-green btn-sm" onclick="confirmContact(\'' + c.id + '\')">Confirm</button>' : '') +
          (c.status !== 'dismissed' ? '<button class="btn btn-red btn-sm" onclick="dismissContact(\'' + c.id + '\')">Dismiss</button>' : '') +
        '</td></tr>';
      }).join('') + '</tbody></table>';
  } catch(e) {
    el.innerHTML = '<div class="empty">Error: ' + e.message + '</div>';
  }
}

async function saveSalesNav(id, url) {
  if (!url) return;
  await fetch('/api/contacts/' + id + '/salesnav', {
    method: 'PATCH', headers: {'Content-Type':'application/json'},
    body: JSON.stringify({ salesNavUrl: url })
  });
}

// ===== CLOSELY IMPORT =====
async function importClosely() {
  var text = document.getElementById('closely-import-text').value.trim();
  var status = document.getElementById('closely-import-status');
  if (!text) { status.textContent = 'Paste CSV first'; return; }
  status.textContent = 'Importing...';
  try {
    var r = await fetch('/api/closely-import', {
      method: 'POST', headers: {'Content-Type':'text/csv'}, body: text
    });
    var d = await r.json();
    status.textContent = d.updated + ' LinkedIn URLs imported';
  } catch(e) { status.textContent = 'Error: ' + e.message; }
}

