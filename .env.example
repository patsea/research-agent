# Job Search Agent — Root Environment Variables
# Copy to .env and fill in your values. Per-agent .env files override these.

# --- Required API Keys ---

# Anthropic API key (used by most agents as ANTHROPIC_API_KEY or CLAUDE_API_KEY)
CLAUDE_API_KEY=sk-ant-...
ANTHROPIC_API_KEY=sk-ant-...

# Attio CRM API key (used by email-scan, research)
ATTIO_API_KEY=

# Attio workspace member ID (for note attribution)
ATTIO_MEMBER_ID=

# FullEnrich API key (used by contact-research)
FULLENRICH_API_KEY=

# --- Optional: Gmail MCP settings ---
# Used by email-scan, outreach-drafter, gmail-hygiene
GMAIL_MCP_COMMAND=npx
GMAIL_MCP_ARGS=-y,@anthropic/gmail-mcp

# --- Optional: Granola MCP settings ---
# Used by email-scan, research
GRANOLA_MCP_COMMAND=npx
GRANOLA_MCP_ARGS=-y,@anthropic/granola-mcp

# --- Optional: Firecrawl (signal-scanner) ---
FIRECRAWL_API_KEY=

# --- Optional: Perplexity (research, manual workflow) ---
PERPLEXITY_API_KEY=

# --- Optional: Model overrides ---
SONNET_MODEL=claude-sonnet-4-6
HAIKU_MODEL=claude-haiku-4-5-20251001
