<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Settings - Job Search Agent</title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #f3f4f6; color: #1f2937; }
  .topbar { background: #fff; border-bottom: 1px solid #e5e7eb; padding: 16px 24px; display: flex; align-items: center; gap: 16px; }
  .topbar a { color: #4f46e5; text-decoration: none; font-size: 14px; }
  .topbar a:hover { text-decoration: underline; }
  .topbar h1 { font-size: 20px; font-weight: 600; }
  .tabs { display: flex; gap: 0; background: #fff; border-bottom: 1px solid #e5e7eb; padding: 0 24px; }
  .tab { padding: 12px 20px; cursor: pointer; font-size: 14px; font-weight: 500; color: #6b7280; border-bottom: 2px solid transparent; transition: all 0.15s; }
  .tab:hover { color: #4f46e5; }
  .tab.active { color: #4f46e5; border-bottom-color: #4f46e5; }
  .container { max-width: 800px; margin: 24px auto; padding: 0 24px; }
  .panel { display: none; }
  .panel.active { display: block; }
  .card { background: #fff; border: 1px solid #e5e7eb; border-radius: 8px; padding: 24px; margin-bottom: 16px; }
  .card h3 { font-size: 16px; font-weight: 600; margin-bottom: 16px; }
  .field-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .field-grid.full { grid-template-columns: 1fr; }
  .field { display: flex; flex-direction: column; gap: 4px; }
  .field label { font-size: 13px; font-weight: 500; color: #374151; }
  .field input, .field textarea, .field select { padding: 8px 12px; border: 1px solid #d1d5db; border-radius: 6px; font-size: 14px; font-family: inherit; }
  .field input:focus, .field textarea:focus { outline: none; border-color: #4f46e5; box-shadow: 0 0 0 2px rgba(79,70,229,0.1); }
  .field textarea { resize: vertical; min-height: 80px; }
  .tags { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 4px; }
  .tag { display: inline-flex; align-items: center; gap: 4px; background: #eef2ff; color: #4f46e5; padding: 4px 10px; border-radius: 999px; font-size: 13px; }
  .tag button { background: none; border: none; color: #4f46e5; cursor: pointer; font-size: 16px; line-height: 1; padding: 0; }
  .tag-input { display: flex; gap: 8px; margin-top: 8px; }
  .tag-input input { flex: 1; }
  .tag-input button, .btn { background: #4f46e5; color: #fff; border: none; padding: 8px 16px; border-radius: 6px; font-size: 14px; cursor: pointer; font-weight: 500; }
  .tag-input button:hover, .btn:hover { background: #4338ca; }
  .btn-sm { padding: 6px 12px; font-size: 13px; }
  .btn-danger { background: #ef4444; }
  .btn-danger:hover { background: #dc2626; }
  .btn-outline { background: #fff; color: #4f46e5; border: 1px solid #4f46e5; }
  .btn-outline:hover { background: #eef2ff; }
  .proof-block { border: 1px solid #e5e7eb; border-radius: 6px; padding: 16px; margin-bottom: 12px; position: relative; }
  .proof-block .remove-proof { position: absolute; top: 8px; right: 8px; }
  .proof-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .save-bar { margin-top: 20px; display: flex; justify-content: flex-end; }
  .toast { position: fixed; bottom: 24px; right: 24px; background: #065f46; color: #fff; padding: 12px 20px; border-radius: 8px; font-size: 14px; opacity: 0; transition: opacity 0.3s; pointer-events: none; z-index: 100; }
  .toast.show { opacity: 1; }
  .placeholder { text-align: center; color: #9ca3af; padding: 60px 20px; font-size: 15px; }
  .status-row { display: flex; gap: 8px; align-items: center; margin-bottom: 8px; }
  .status-row input { flex: 1; }
  .status-row input.color-input { width: 50px; flex: none; padding: 2px; }
</style>
</head>
<body>

<div class="topbar">
  <a href="index.html">&larr; Dashboard</a>
  <h1>Settings</h1>
</div>

<div class="tabs">
  <div class="tab active" data-tab="profile">User Profile</div>
  <div class="tab" data-tab="attio">Attio Fields</div>
  <div class="tab" data-tab="rubric">Scoring Rubric</div>
  <div class="tab" data-tab="positioning">Positioning</div>
</div>

<div class="container">
  <!-- User Profile Panel -->
  <div class="panel active" id="panel-profile">
    <div class="card">
      <h3>Basic Information</h3>
      <div class="field-grid">
        <div class="field"><label>Full Name</label><input type="text" id="up-name"></div>
        <div class="field"><label>Current Title</label><input type="text" id="up-title"></div>
        <div class="field"><label>Years of Experience</label><input type="number" id="up-years"></div>
        <div class="field"><label>Degree</label><input type="text" id="up-degree"></div>
        <div class="field"><label>School</label><input type="text" id="up-school"></div>
        <div class="field"><label>Location</label><input type="text" id="up-location"></div>
      </div>
    </div>
    <div class="card">
      <h3>Positioning Statement</h3>
      <div class="field-grid full">
        <div class="field"><label>Your positioning / elevator pitch</label><textarea id="up-positioning" rows="4"></textarea></div>
      </div>
    </div>
    <div class="card">
      <h3>Proof Points</h3>
      <div id="proof-points-list"></div>
      <button class="btn btn-outline btn-sm" onclick="addProofPoint()">+ Add Proof Point</button>
    </div>
    <div class="card">
      <h3>Target Roles</h3>
      <div class="tags" id="tags-roles"></div>
      <div class="tag-input"><input type="text" id="input-roles" placeholder="Add a role..."><button onclick="addTag('roles')">Add</button></div>
    </div>
    <div class="card">
      <h3>Target Sectors</h3>
      <div class="tags" id="tags-sectors"></div>
      <div class="tag-input"><input type="text" id="input-sectors" placeholder="Add a sector..."><button onclick="addTag('sectors')">Add</button></div>
    </div>
    <div class="card">
      <h3>Target Geographies</h3>
      <div class="tags" id="tags-geographies"></div>
      <div class="tag-input"><input type="text" id="input-geographies" placeholder="Add a geography..."><button onclick="addTag('geographies')">Add</button></div>
    </div>
    <div class="save-bar"><button class="btn" onclick="saveProfile()">Save User Profile</button></div>
  </div>

  <!-- Attio Fields Panel -->
  <div class="panel" id="panel-attio">
    <div class="card">
      <h3>Field Slugs</h3>
      <div class="field-grid">
        <div class="field"><label>Status Field Slug</label><input type="text" id="af-status-slug" placeholder="e.g. status"></div>
        <div class="field"><label>Next Action Field Slug</label><input type="text" id="af-action-slug" placeholder="e.g. next_action"></div>
      </div>
      <div class="field-grid" style="margin-top:16px">
        <div class="field"><label>Workspace Member ID</label><input type="text" id="af-member-id" placeholder="Your Attio workspace member ID"></div>
      </div>
    </div>
    <div class="card">
      <h3>Status Values</h3>
      <p style="font-size:13px;color:#6b7280;margin-bottom:12px">Define the status values and their display colours.</p>
      <div id="status-values-list"></div>
      <button class="btn btn-outline btn-sm" onclick="addStatusValue()">+ Add Status</button>
    </div>
    <div class="card">
      <h3>Protected Statuses</h3>
      <p style="font-size:13px;color:#6b7280;margin-bottom:8px">Statuses that should not be automatically changed by agents.</p>
      <div class="tags" id="tags-protected"></div>
      <div class="tag-input"><input type="text" id="input-protected" placeholder="Add a protected status..."><button onclick="addTag('protected')">Add</button></div>
    </div>
    <div class="save-bar"><button class="btn" onclick="saveAttio()">Save Attio Fields</button></div>
  </div>

  <!-- Scoring Rubric Panel -->
  <div class="panel" id="panel-rubric">
    <div class="card">
      <h3>Company Scoring Rubric</h3>
      <p style="font-size:13px;color:#6b7280;margin-bottom:12px">Define the dimensions used to score target companies. Weights must sum to 1.0.</p>
      <div id="company-dims"></div>
      <button class="btn btn-outline btn-sm" onclick="addDim('company')" style="margin-top:8px">+ Add Dimension</button>
    </div>
    <div class="card">
      <h3>Firm Scoring Rubric</h3>
      <p style="font-size:13px;color:#6b7280;margin-bottom:12px">Define the dimensions used to score executive search firms. Weights must sum to 1.0.</p>
      <div id="firm-dims"></div>
      <button class="btn btn-outline btn-sm" onclick="addDim('firm')" style="margin-top:8px">+ Add Dimension</button>
    </div>
    <div class="card">
      <h3>Score Thresholds</h3>
      <p style="font-size:13px;color:#6b7280;margin-bottom:12px">Minimum scores to classify leads into tiers.</p>
      <div class="field-grid">
        <div class="field"><label>Company — Hot (min score)</label><input type="number" id="thresh-hot" step="0.01" min="0" max="1"></div>
        <div class="field"><label>Company — Warm (min score)</label><input type="number" id="thresh-warm" step="0.01" min="0" max="1"></div>
        <div class="field"><label>Firm — Tier 1 (min score)</label><input type="number" id="thresh-tier1" step="0.01" min="0" max="1"></div>
        <div class="field"><label>Firm — Tier 2 (min score)</label><input type="number" id="thresh-tier2" step="0.01" min="0" max="1"></div>
      </div>
    </div>
    <div class="save-bar"><button class="btn" onclick="saveRubric()">Save Scoring Rubric</button></div>
  </div>

  <!-- Positioning Panel -->
  <div class="panel" id="panel-positioning">
    <div class="card">
      <h3>Outreach Positioning</h3>
      <p style="font-size:13px;color:#6b7280;margin-bottom:12px">Markdown document used by the Outreach Drafter as your voice and positioning guide.</p>
      <div class="field-grid full">
        <div class="field">
          <label>POSITIONING.md</label>
          <textarea id="pos-content" style="font-family:'SF Mono',Monaco,Menlo,monospace;font-size:13px;min-height:480px;line-height:1.5" oninput="updateWordCount()"></textarea>
        </div>
      </div>
      <div style="display:flex;justify-content:space-between;align-items:center;margin-top:8px">
        <span id="pos-word-count" style="font-size:13px;color:#6b7280">0 words</span>
        <div style="display:flex;gap:8px">
          <button class="btn btn-outline" onclick="loadPositioning()">Reload</button>
          <button class="btn" onclick="savePositioning()">Save Positioning</button>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="toast" id="toast">Saved successfully</div>

<script>
  // --- Tab switching ---
  document.querySelectorAll('.tab').forEach(t => {
    t.addEventListener('click', () => {
      document.querySelectorAll('.tab').forEach(x => x.classList.remove('active'));
      document.querySelectorAll('.panel').forEach(x => x.classList.remove('active'));
      t.classList.add('active');
      document.getElementById('panel-' + t.dataset.tab).classList.add('active');
    });
  });

  // --- Tags ---
  const tagData = { roles: [], sectors: [], geographies: [], protected: [] };

  function renderTags(key) {
    const el = document.getElementById('tags-' + key);
    el.innerHTML = tagData[key].map((v, i) =>
      `<span class="tag">${v}<button onclick="removeTag('${key}',${i})">&times;</button></span>`
    ).join('');
  }

  function addTag(key) {
    const input = document.getElementById('input-' + key);
    const val = input.value.trim();
    if (val && !tagData[key].includes(val)) { tagData[key].push(val); renderTags(key); }
    input.value = '';
  }

  function removeTag(key, i) { tagData[key].splice(i, 1); renderTags(key); }

  // Enter key for tag inputs
  ['roles','sectors','geographies','protected'].forEach(k => {
    document.getElementById('input-' + k).addEventListener('keydown', e => { if (e.key === 'Enter') { e.preventDefault(); addTag(k); } });
  });

  // --- Proof Points ---
  let proofPoints = [];

  function renderProofPoints() {
    const el = document.getElementById('proof-points-list');
    el.innerHTML = proofPoints.map((p, i) => `
      <div class="proof-block">
        <button class="btn btn-danger btn-sm remove-proof" onclick="removeProofPoint(${i})">Remove</button>
        <div class="proof-grid">
          <div class="field"><label>Company</label><input type="text" value="${esc(p.company)}" onchange="proofPoints[${i}].company=this.value"></div>
          <div class="field"><label>Role</label><input type="text" value="${esc(p.role)}" onchange="proofPoints[${i}].role=this.value"></div>
          <div class="field"><label>Highlight</label><input type="text" value="${esc(p.highlight)}" onchange="proofPoints[${i}].highlight=this.value"></div>
          <div class="field"><label>Note</label><input type="text" value="${esc(p.note)}" onchange="proofPoints[${i}].note=this.value"></div>
        </div>
      </div>`).join('');
  }

  function addProofPoint() { proofPoints.push({ company: '', role: '', highlight: '', note: '' }); renderProofPoints(); }
  function removeProofPoint(i) { proofPoints.splice(i, 1); renderProofPoints(); }
  function esc(s) { return (s || '').replace(/"/g, '&quot;'); }

  // --- Status Values ---
  let statusValues = [];

  function renderStatusValues() {
    const el = document.getElementById('status-values-list');
    el.innerHTML = statusValues.map((s, i) => `
      <div class="status-row">
        <input type="text" value="${esc(s.label)}" placeholder="Label" onchange="statusValues[${i}].label=this.value">
        <input type="text" value="${esc(s.slug)}" placeholder="Slug" onchange="statusValues[${i}].slug=this.value">
        <input type="color" class="color-input" value="${s.color || '#4f46e5'}" onchange="statusValues[${i}].color=this.value">
        <button class="btn btn-danger btn-sm" onclick="removeStatus(${i})">Remove</button>
      </div>`).join('');
  }

  function addStatusValue() { statusValues.push({ label: '', slug: '', color: '#4f46e5' }); renderStatusValues(); }
  function removeStatus(i) { statusValues.splice(i, 1); renderStatusValues(); }

  // --- Toast ---
  function showToast(msg) {
    const t = document.getElementById('toast');
    t.textContent = msg || 'Saved successfully';
    t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 2500);
  }

  // --- Load / Save: User Profile ---
  async function loadUserProfile() {
    try {
      const res = await fetch('/api/config/user-profile');
      if (!res.ok) return;
      const d = await res.json();
      document.getElementById('up-name').value = d.name || '';
      document.getElementById('up-title').value = d.title || '';
      document.getElementById('up-years').value = d.yearsExperience || '';
      document.getElementById('up-degree').value = d.degree || '';
      document.getElementById('up-school').value = d.school || '';
      document.getElementById('up-location').value = d.location || '';
      document.getElementById('up-positioning').value = d.positioning || '';
      proofPoints = d.proofPoints || []; renderProofPoints();
      tagData.roles = d.targetRoles || []; renderTags('roles');
      tagData.sectors = d.targetSectors || []; renderTags('sectors');
      tagData.geographies = d.targetGeographies || []; renderTags('geographies');
    } catch (e) { console.error('Failed to load user profile', e); }
  }

  async function saveProfile() {
    const body = {
      name: document.getElementById('up-name').value,
      title: document.getElementById('up-title').value,
      yearsExperience: parseInt(document.getElementById('up-years').value) || 0,
      degree: document.getElementById('up-degree').value,
      school: document.getElementById('up-school').value,
      location: document.getElementById('up-location').value,
      positioning: document.getElementById('up-positioning').value,
      proofPoints,
      targetRoles: tagData.roles,
      targetSectors: tagData.sectors,
      targetGeographies: tagData.geographies
    };
    const res = await fetch('/api/config/user-profile', { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
    showToast(res.ok ? 'User profile saved' : 'Save failed');
  }

  // --- Load / Save: Attio Fields ---
  async function loadAttioFields() {
    try {
      const res = await fetch('/api/config/attio-fields');
      if (!res.ok) return;
      const d = await res.json();
      document.getElementById('af-status-slug').value = d.statusFieldSlug || '';
      document.getElementById('af-action-slug').value = d.nextActionFieldSlug || '';
      document.getElementById('af-member-id').value = d.workspaceMemberId || '';
      statusValues = d.statusValues || []; renderStatusValues();
      tagData.protected = d.protectedStatuses || []; renderTags('protected');
    } catch (e) { console.error('Failed to load attio fields', e); }
  }

  async function saveAttio() {
    const body = {
      statusFieldSlug: document.getElementById('af-status-slug').value,
      nextActionFieldSlug: document.getElementById('af-action-slug').value,
      workspaceMemberId: document.getElementById('af-member-id').value,
      statusValues,
      protectedStatuses: tagData.protected
    };
    const res = await fetch('/api/config/attio-fields', { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
    showToast(res.ok ? 'Attio fields saved' : 'Save failed');
  }

  // --- Scoring Rubric ---
  let rubricData = { company: { dimensions: [] }, firm: { dimensions: [] } };

  function renderDims(type) {
    const dims = type === 'company' ? rubricData.company.dimensions : rubricData.firm.dimensions;
    const el = document.getElementById(type + '-dims');
    el.innerHTML = dims.map((d, i) => `
      <div class="proof-block">
        <button class="btn btn-danger btn-sm remove-proof" onclick="removeDim('${type}',${i})">Remove</button>
        <div class="proof-grid">
          <div class="field"><label>ID</label><input type="text" value="${esc(d.id)}" onchange="rubricData.${type}.dimensions[${i}].id=this.value"></div>
          <div class="field"><label>Weight (0-1)</label><input type="number" step="0.01" min="0" max="1" value="${d.weight||0}" onchange="rubricData.${type}.dimensions[${i}].weight=parseFloat(this.value)||0"></div>
        </div>
        <div class="field" style="margin-top:8px"><label>Name</label><input type="text" value="${esc(d.name)}" onchange="rubricData.${type}.dimensions[${i}].name=this.value"></div>
        <div class="field" style="margin-top:8px"><label>Prompt</label><textarea rows="2" onchange="rubricData.${type}.dimensions[${i}].prompt=this.value">${esc(d.prompt)}</textarea></div>
      </div>`).join('');
  }

  function addDim(type) {
    const dims = type === 'company' ? rubricData.company.dimensions : rubricData.firm.dimensions;
    dims.push({ id: '', name: '', weight: 0, prompt: '' });
    renderDims(type);
  }

  function removeDim(type, i) {
    const dims = type === 'company' ? rubricData.company.dimensions : rubricData.firm.dimensions;
    dims.splice(i, 1);
    renderDims(type);
  }

  async function loadRubric() {
    try {
      const res = await fetch('/api/config/scoring-rubric');
      if (!res.ok) return;
      const d = await res.json();
      rubricData.company = d.company || { dimensions: [] };
      rubricData.firm = d.firm || { dimensions: [] };
      if (!rubricData.company.dimensions) rubricData.company.dimensions = [];
      if (!rubricData.firm.dimensions) rubricData.firm.dimensions = [];
      renderDims('company');
      renderDims('firm');
      document.getElementById('thresh-hot').value = (d.company && d.company.thresholds && d.company.thresholds.hot) || '';
      document.getElementById('thresh-warm').value = (d.company && d.company.thresholds && d.company.thresholds.warm) || '';
      document.getElementById('thresh-tier1').value = (d.firm && d.firm.thresholds && d.firm.thresholds.tier1) || '';
      document.getElementById('thresh-tier2').value = (d.firm && d.firm.thresholds && d.firm.thresholds.tier2) || '';
    } catch (e) { console.error('Failed to load rubric', e); }
  }

  async function saveRubric() {
    rubricData.company.thresholds = {
      hot: parseFloat(document.getElementById('thresh-hot').value) || 0,
      warm: parseFloat(document.getElementById('thresh-warm').value) || 0
    };
    rubricData.firm.thresholds = {
      tier1: parseFloat(document.getElementById('thresh-tier1').value) || 0,
      tier2: parseFloat(document.getElementById('thresh-tier2').value) || 0
    };
    const res = await fetch('/api/config/scoring-rubric', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(rubricData) });
    showToast(res.ok ? 'Scoring rubric saved' : 'Save failed');
  }

  // --- Positioning ---
  function updateWordCount() {
    const text = document.getElementById('pos-content').value.trim();
    const count = text ? text.split(/\s+/).length : 0;
    document.getElementById('pos-word-count').textContent = count + ' word' + (count !== 1 ? 's' : '');
  }

  async function loadPositioning() {
    try {
      const res = await fetch('/api/config/positioning');
      if (!res.ok) return;
      const d = await res.json();
      document.getElementById('pos-content').value = d.content || '';
      updateWordCount();
    } catch (e) { console.error('Failed to load positioning', e); }
  }

  async function savePositioning() {
    const content = document.getElementById('pos-content').value;
    const res = await fetch('/api/config/positioning', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ content }) });
    showToast(res.ok ? 'Positioning saved' : 'Save failed');
  }

  // --- Init ---
  loadUserProfile();
  loadAttioFields();
  loadRubric();
  loadPositioning();
</script>
</body>
</html>
