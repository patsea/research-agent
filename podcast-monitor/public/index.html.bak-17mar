<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Podcast Monitor</title>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{background:#f5f5f5;color:#1a1a1a;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;font-size:14px;line-height:1.5}
.header{background:#fff;border-bottom:1px solid #e0e0e0;padding:16px 24px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:10}
.header h1{font-size:18px;font-weight:600;color:#1a1a1a}
.header h1 span{color:#4a90d9}
.tabs{display:flex;gap:0;background:#fff;border-bottom:1px solid #e0e0e0;position:sticky;top:57px;z-index:9}
.tab{padding:10px 24px;cursor:pointer;font-size:13px;font-weight:500;color:#888;border-bottom:2px solid transparent;transition:all .15s}
.tab:hover{color:#1a1a1a}
.tab.active{color:#4a90d9;border-bottom-color:#4a90d9}
.content{padding:20px 24px;max-width:1200px;margin:0 auto}
.hidden{display:none!important}

/* Cards */
.grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
@media(max-width:900px){.grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:600px){.grid{grid-template-columns:1fr}}
.card{background:#fff;border:1px solid #e0e0e0;border-radius:8px;padding:16px;box-shadow:0 1px 3px rgba(0,0,0,.06);transition:box-shadow .15s}
.card:hover{box-shadow:0 2px 8px rgba(0,0,0,.1)}
.card-thumb{width:100%;height:120px;object-fit:cover;border-radius:6px;margin-bottom:10px;background:#eee}
.card-thumb-placeholder{width:100%;height:120px;border-radius:6px;margin-bottom:10px;background:#eee;display:flex;align-items:center;justify-content:center;color:#bbb;font-size:32px}
.card-title{font-size:14px;font-weight:600;margin-bottom:6px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.card-meta{font-size:12px;color:#888;margin-bottom:8px}
.badge{display:inline-block;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:600}
.badge-new{background:#e3f2fd;color:#1976d2}
.badge-processing{background:#fff3e0;color:#f57c00}
.badge-summarised{background:#e8f5e9;color:#388e3c}
.badge-dismissed{background:#f5f5f5;color:#999}
.card-actions{display:flex;gap:8px;margin-top:10px}
.btn{padding:6px 14px;border-radius:6px;font-size:12px;font-weight:500;cursor:pointer;border:1px solid #e0e0e0;background:#fff;color:#666;transition:all .1s}
.btn:hover{border-color:#999;color:#333}
.btn:disabled{opacity:.4;cursor:not-allowed}
.btn-primary{background:#4a90d9;color:#fff;border-color:#4a90d9}
.btn-primary:hover{background:#3a7bc8}
.btn-danger{color:#e53935;border-color:#ffcdd2}
.btn-danger:hover{background:#ffebee}

/* Filters */
.toolbar{display:flex;align-items:center;gap:12px;margin-bottom:16px;flex-wrap:wrap}
.pill{padding:5px 14px;border-radius:20px;font-size:12px;cursor:pointer;border:1px solid #e0e0e0;background:#fff;color:#666;transition:all .1s}
.pill.active{background:#4a90d9;color:#fff;border-color:#4a90d9}

/* Summaries */
.summary-row{background:#fff;border:1px solid #e0e0e0;border-radius:8px;padding:14px 16px;margin-bottom:10px;box-shadow:0 1px 3px rgba(0,0,0,.06)}
.summary-header{display:flex;align-items:center;justify-content:space-between;gap:12px;cursor:pointer}
.summary-title{font-weight:600;font-size:14px;flex:1}
.summary-meta{font-size:12px;color:#888}
.tag-badge{display:inline-block;padding:2px 8px;border-radius:4px;font-size:11px;background:#e8f5e9;color:#388e3c;margin-left:4px}
.summary-detail{margin-top:14px;padding-top:14px;border-top:1px solid #eee}
.summary-text{font-size:13px;line-height:1.7;color:#444;margin-bottom:14px}
.hl-table{width:100%;border-collapse:collapse;font-size:12px}
.hl-table th{text-align:left;padding:8px;border-bottom:1px solid #e0e0e0;color:#888;font-weight:500}
.hl-table td{padding:8px;border-bottom:1px solid #f0f0f0}
.ts-link{color:#4a90d9;cursor:pointer;font-family:monospace;font-size:12px}
.ts-link:hover{text-decoration:underline}

/* Settings */
.settings-section{margin-bottom:32px}
.settings-section h3{font-size:14px;font-weight:600;margin-bottom:12px;color:#333}
.settings-row{background:#fff;border:1px solid #e0e0e0;border-radius:8px;padding:12px 16px;display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:8px}
.settings-info{flex:1;min-width:0}
.settings-name{font-weight:500;font-size:13px}
.settings-url{font-size:11px;color:#888;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.settings-polled{font-size:11px;color:#aaa}
.form-row{display:flex;gap:8px;margin-bottom:8px}
.input{background:#fff;border:1px solid #e0e0e0;color:#1a1a1a;padding:8px 12px;border-radius:6px;font-size:13px;flex:1}
.input:focus{outline:none;border-color:#4a90d9}
.tags-wrap{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:12px}
.tag-pill{background:#e3f2fd;color:#1976d2;padding:4px 10px;border-radius:4px;font-size:12px;display:flex;align-items:center;gap:6px}
.tag-pill button{background:none;border:none;color:#1976d2;cursor:pointer;font-size:14px;line-height:1;padding:0}
.tag-pill button:hover{color:#e53935}

/* Modal */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.3);z-index:100;display:flex;align-items:center;justify-content:center}
.modal{background:#fff;border-radius:10px;padding:24px;width:420px;max-width:90vw;box-shadow:0 8px 32px rgba(0,0,0,.15)}
.modal h3{font-size:16px;margin-bottom:16px}

/* Toast */
.toast{position:fixed;bottom:24px;right:24px;background:#fff;border:1px solid #e0e0e0;border-radius:8px;padding:12px 16px;font-size:13px;z-index:999;box-shadow:0 4px 16px rgba(0,0,0,.1);animation:fadeIn .2s ease}
@keyframes fadeIn{from{transform:translateY(8px);opacity:0}to{transform:translateY(0);opacity:1}}

/* Topic tags & deep summary */
.topic-tag-block{border:1px solid #e0e0e0;border-radius:6px;padding:12px 16px;margin:8px 0;background:#fafafa}
.topic-tag-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:4px}
.topic-label{font-weight:600;font-size:13px;color:#1a1a1a}
.topic-timestamp{font-size:12px;color:#666;font-family:monospace}
.topic-teaser{font-size:13px;color:#444;margin:4px 0 8px}
.deep-summary-btn{font-size:12px;color:#3b5bdb;background:none;border:1px solid #c5d0fa;border-radius:4px;padding:4px 10px;cursor:pointer}
.deep-summary-btn:hover{background:#f0f4ff}
.deep-summary-content{margin-top:10px;padding:10px;background:#fff;border-radius:4px;border:1px solid #e8e8e8;font-size:13px;line-height:1.6;color:#222}
.deep-summary-content p{margin:0 0 10px}
.desc-text{font-size:13px;color:#555;line-height:1.5;white-space:pre-wrap;word-break:break-word}

/* Suggested tags */
.suggested-tags{background:#fffde7;border:1px solid #ffe082;border-radius:6px;padding:10px 14px;margin-top:12px}
.suggested-tags-label{font-size:12px;font-weight:600;color:#f9a825;margin-bottom:6px}
.suggested-tag{display:inline-flex;align-items:center;gap:4px;background:#fff8e1;border:1px solid #ffe082;border-radius:4px;padding:3px 8px;margin:3px 4px 3px 0;font-size:12px;color:#333}
.suggested-tag button{background:#4caf50;color:#fff;border:none;border-radius:3px;padding:1px 8px;font-size:11px;cursor:pointer}
.suggested-tag button:hover{background:#388e3c}
.suggested-tag button:disabled{opacity:.4;cursor:not-allowed}
</style>
</head>
<body>

<div class="header">
  <h1><span>Podcast</span> Monitor</h1>
  <div style="font-size:12px;color:#888" id="status-indicator"></div>
</div>

<div class="tabs">
  <div class="tab active" data-tab="queue">Queue</div>
  <div class="tab" data-tab="summaries">Summaries</div>
  <div class="tab" data-tab="settings">Settings</div>
</div>

<!-- QUEUE TAB -->
<div class="content" id="tab-queue">
  <div class="toolbar">
    <div class="pill active" data-filter="all">All</div>
    <div class="pill" data-filter="new">New</div>
    <div class="pill" data-filter="summarised">Summarised</div>
    <div style="margin-left:auto">
      <button class="btn btn-primary" onclick="showAddUrlModal()">+ Add URL</button>
    </div>
  </div>
  <div class="grid" id="episodes-grid"></div>
</div>

<!-- SUMMARIES TAB -->
<div class="content hidden" id="tab-summaries">
  <div id="summaries-list"></div>
</div>

<!-- SETTINGS TAB -->
<div class="content hidden" id="tab-settings">
  <div class="settings-section">
    <h3>RSS Feeds</h3>
    <div id="feeds-list"></div>
    <div class="form-row" style="margin-top:12px">
      <input class="input" id="feed-name" placeholder="Feed name">
      <input class="input" id="feed-url" placeholder="RSS feed URL">
      <button class="btn btn-primary" onclick="addFeed()">Add Feed</button>
    </div>
    <button class="btn" onclick="pollAll()" style="margin-top:8px">Poll all feeds now</button>

    <div style="margin-top:20px;padding-top:16px;border-top:1px solid #eee">
      <h4 style="font-size:13px;font-weight:600;margin:0 0 10px">Subscribe to YouTube Channel</h4>
      <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap">
        <input id="yt-channel-input" type="text" placeholder="@handle or youtube.com/@channel or channel ID"
          class="input" style="flex:1;min-width:200px">
        <input id="yt-backfill" type="number" min="0" max="50" value="0"
          placeholder="Backfill"
          class="input" style="width:80px"
          title="Enter a number to load the last N episodes on first subscribe. 0 = new episodes only.">
        <button id="yt-add-btn" class="btn btn-primary" onclick="addYouTubeChannel()"
          style="background:#ff0000;border-color:#ff0000">
          Subscribe
        </button>
      </div>
      <p style="font-size:11px;color:#888;margin:6px 0 0">Backfill: 0 = new episodes only. Enter a number (e.g. 5) to also load the last N episodes.</p>
    </div>
  </div>
  <div class="settings-section">
    <h3>Interest Tags</h3>
    <div class="tags-wrap" id="tags-list"></div>
    <div class="form-row">
      <input class="input" id="tag-text" placeholder="New tag">
      <button class="btn btn-primary" onclick="addTag()">Add Tag</button>
    </div>
  </div>
</div>

<script>
const API = '';
let currentTab = 'queue';
let statusFilter = 'all';
let expandedSummary = null;

// --- Tabs ---
document.querySelectorAll('.tab').forEach(t => {
  t.addEventListener('click', () => {
    document.querySelectorAll('.tab').forEach(x => x.classList.remove('active'));
    t.classList.add('active');
    currentTab = t.dataset.tab;
    document.querySelectorAll('.content').forEach(c => c.classList.add('hidden'));
    document.getElementById('tab-' + currentTab).classList.remove('hidden');
    if (currentTab === 'queue') loadEpisodes();
    if (currentTab === 'summaries') loadSummaries();
    if (currentTab === 'settings') { loadFeeds(); loadTags(); }
  });
});

// --- Filters ---
document.querySelectorAll('.pill').forEach(p => {
  p.addEventListener('click', () => {
    document.querySelectorAll('.pill').forEach(x => x.classList.remove('active'));
    p.classList.add('active');
    statusFilter = p.dataset.filter;
    loadEpisodes();
  });
});

// --- Episodes ---
async function loadEpisodes() {
  const url = statusFilter === 'all' ? '/api/episodes' : `/api/episodes?status=${statusFilter}`;
  const data = await fetch(url).then(r => r.json());
  const grid = document.getElementById('episodes-grid');
  if (!data.length) {
    grid.innerHTML = '<div style="grid-column:1/-1;text-align:center;padding:60px 0;color:#888"><h3>No episodes</h3><p>Add an RSS feed or paste a URL to get started.</p></div>';
    return;
  }
  grid.innerHTML = data.map(ep => {
    const thumb = ep.thumbnail
      ? `<img class="card-thumb" src="${esc(ep.thumbnail)}" onerror="this.outerHTML='<div class=card-thumb-placeholder>&#127911;</div>'">`
      : '<div class="card-thumb-placeholder">&#127911;</div>';
    const badgeClass = 'badge-' + ep.status;
    const disableSummarise = ep.status === 'processing' || ep.status === 'summarised';
    return `<div class="card">
      ${thumb}
      <div class="card-title" title="${esc(ep.title)}">${esc(ep.title)}</div>
      <div class="card-meta">${esc(ep.feed_name || 'Manual')} &middot; ${fmtDate(ep.published_at)}${ep.duration ? ' &middot; ' + Math.round(ep.duration/60) + ' min' : ''}</div>
      ${ep.description ? '<div class="desc-text" style="margin:4px 0 8px;max-height:60px;overflow:hidden;font-size:12px">' + esc(ep.description).slice(0,200) + (ep.description.length > 200 ? '...' : '') + '</div>' : ''}
      <span class="badge ${badgeClass}">${ep.status}</span>
      <div class="card-actions">
        <button class="btn" onclick="dismiss(${ep.id})" ${ep.status==='dismissed'?'disabled':''}>Dismiss</button>
        <button class="btn btn-primary" onclick="summariseEp(${ep.id})" ${disableSummarise?'disabled':''}>${ep.status==='processing'?'Processing...':'Summarise'}</button>
      </div>
    </div>`;
  }).join('');
}

async function dismiss(id) {
  await fetch(`/api/episodes/${id}/dismiss`, { method: 'PATCH' });
  loadEpisodes();
}

async function summariseEp(id) {
  await fetch(`/api/episodes/${id}/summarise`, { method: 'POST' });
  toast('Processing started — this may take a few minutes');
  loadEpisodes();
}

// --- Add URL Modal ---
function showAddUrlModal() {
  const overlay = document.createElement('div');
  overlay.className = 'modal-overlay';
  overlay.innerHTML = `<div class="modal">
    <h3>Add URL</h3>
    <input class="input" id="modal-url" placeholder="YouTube or podcast URL" style="width:100%;margin-bottom:12px">
    <input class="input" id="modal-title" placeholder="Title (optional)" style="width:100%;margin-bottom:16px">
    <div style="display:flex;gap:8px;justify-content:flex-end">
      <button class="btn" onclick="this.closest('.modal-overlay').remove()">Cancel</button>
      <button class="btn btn-primary" onclick="submitUrl()">Add</button>
    </div>
  </div>`;
  overlay.addEventListener('click', e => { if (e.target === overlay) overlay.remove(); });
  document.body.appendChild(overlay);
  document.getElementById('modal-url').focus();
}

async function submitUrl() {
  const url = document.getElementById('modal-url').value.trim();
  const title = document.getElementById('modal-title').value.trim();
  if (!url) return;
  await fetch('/api/episodes/url', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ url, title: title || undefined })
  });
  document.querySelector('.modal-overlay').remove();
  toast('URL added');
  loadEpisodes();
}

// --- Topic tag helpers ---
function tsToSecs(ts) {
  const parts = ts.split(':').map(Number);
  return parts.length === 3 ? parts[0]*3600 + parts[1]*60 + parts[2] : parts[0]*60 + parts[1];
}

function timestampLink(sourceUrl, ts) {
  const secs = tsToSecs(ts);
  if (sourceUrl && (sourceUrl.includes('youtube.com') || sourceUrl.includes('youtu.be'))) {
    return sourceUrl + (sourceUrl.includes('?') ? '&' : '?') + 't=' + secs;
  }
  return sourceUrl || '#';
}

async function loadDeepSummary(summaryId, topicIndex, btnEl, containerEl) {
  btnEl.textContent = 'Loading...';
  btnEl.disabled = true;
  try {
    const r = await fetch('/api/summaries/' + summaryId + '/section', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({topic_index: topicIndex})
    });
    const d = await r.json();
    if (d.error) throw new Error(d.error);
    containerEl.innerHTML = d.deep_summary.split('\n\n').map(p => '<p>' + esc(p) + '</p>').join('');
    containerEl.style.display = 'block';
    btnEl.textContent = 'Hide';
    btnEl.disabled = false;
    btnEl.onclick = () => {
      const visible = containerEl.style.display !== 'none';
      containerEl.style.display = visible ? 'none' : 'block';
      btnEl.textContent = visible ? '\u25b6 Deep summary' : 'Hide';
    };
  } catch(e) {
    containerEl.innerHTML = '<p style="color:red">Error: ' + e.message + '</p>';
    containerEl.style.display = 'block';
    btnEl.textContent = '\u25b6 Deep summary';
    btnEl.disabled = false;
  }
}

function renderTopicTags(summaryId, tags, sourceUrl) {
  if (!tags || !tags.length) return '<p style="color:#999">No topic tags generated</p>';
  return tags.map((tag, i) => {
    const tsLink = timestampLink(sourceUrl, tag.timestamp_start);
    const containerId = 'ds-content-' + summaryId + '-' + i;
    const btnId = 'ds-btn-' + summaryId + '-' + i;
    return `<div class="topic-tag-block">
      <div class="topic-tag-header">
        <span class="topic-label">${esc(tag.topic).toUpperCase()}</span>
        <a class="ts-link" href="${tsLink}" target="_blank">${esc(tag.timestamp_start)} \u2013 ${esc(tag.timestamp_end)}</a>
      </div>
      <div class="topic-teaser">${esc(tag.teaser)}</div>
      <button class="deep-summary-btn" id="${btnId}" onclick="(function(btn){
        var container = document.getElementById('${containerId}');
        if (container.dataset.loaded) {
          var visible = container.style.display !== 'none';
          container.style.display = visible ? 'none' : 'block';
          btn.textContent = visible ? '\u25b6 Deep summary' : 'Hide';
        } else {
          container.dataset.loaded = '1';
          loadDeepSummary('${summaryId}', ${i}, btn, container);
        }
      })(this)">\u25b6 Deep summary</button>
      <div class="deep-summary-content" id="${containerId}" style="display:none"></div>
    </div>`;
  }).join('');
}

// --- Summaries ---
async function loadSummaries() {
  const data = await fetch('/api/summaries').then(r => r.json());
  const list = document.getElementById('summaries-list');
  if (!data.length) {
    list.innerHTML = '<div style="text-align:center;padding:60px 0;color:#888"><h3>No summaries yet</h3><p>Summarise an episode from the Queue tab.</p></div>';
    return;
  }
  list.innerHTML = data.map(s => {
    const topicTags = s.topic_tags || [];
    const isExpanded = expandedSummary === s.id;
    return `<div class="summary-row">
      <div class="summary-header" onclick="toggleSummary(${s.id})">
        <div class="summary-title">${esc(s.title)}</div>
        <div class="summary-meta">${fmtDate(s.published_at)} &middot; ${s.word_count || '?'} words${topicTags.length ? ' &middot; ' + topicTags.length + ' topics' : ''}</div>
        <span style="font-size:18px;color:#888">${isExpanded ? '&#9660;' : '&#9654;'}</span>
      </div>
      ${isExpanded ? `<div class="summary-detail">
        <h4 style="font-size:13px;font-weight:600;color:#888;margin-bottom:8px">OVERVIEW</h4>
        <div class="summary-text">${esc(s.summary_text)}</div>
        <h4 style="font-size:13px;font-weight:600;color:#888;margin:16px 0 8px">TOPICS</h4>
        ${renderTopicTags(s.id, topicTags, s.source_url)}
        <div id="suggested-tags-${s.id}"></div>
        <div style="margin-top:10px"><a href="${esc(s.source_url)}" target="_blank" style="color:#4a90d9;font-size:12px">Open source &rarr;</a></div>
      </div>` : ''}
    </div>`;
  }).join('');
}

function toggleSummary(id) {
  expandedSummary = expandedSummary === id ? null : id;
  loadSummaries().then(() => {
    if (expandedSummary !== null) {
      const container = document.getElementById('suggested-tags-' + expandedSummary);
      if (container) renderSuggestedTags(expandedSummary, container);
    }
  });
}

// --- Feeds ---
async function loadFeeds() {
  const data = await fetch('/api/feeds').then(r => r.json());
  const list = document.getElementById('feeds-list');
  list.innerHTML = data.map(f => `<div class="settings-row" style="flex-wrap:wrap">
    <div class="settings-info">
      <div class="settings-name">${esc(f.name)}</div>
      <div class="settings-url">${esc(f.url)}</div>
      <div class="settings-polled">Last polled: ${f.last_polled ? fmtDate(f.last_polled) : 'never'}</div>
    </div>
    <button class="btn btn-danger" onclick="deleteFeed(${f.id})">Delete</button>
    <div style="width:100%;display:flex;gap:14px;margin-top:8px;font-size:12px;color:#666">
      <label><input type="checkbox" ${f.show_title ? 'checked' : ''} onchange="patchFeedMeta(${f.id},'show_title',this.checked)"> Title</label>
      <label><input type="checkbox" ${f.show_published ? 'checked' : ''} onchange="patchFeedMeta(${f.id},'show_published',this.checked)"> Date</label>
      <label><input type="checkbox" ${f.show_duration ? 'checked' : ''} onchange="patchFeedMeta(${f.id},'show_duration',this.checked)"> Duration</label>
      <label><input type="checkbox" ${f.show_description ? 'checked' : ''} onchange="patchFeedMeta(${f.id},'show_description',this.checked)"> Description</label>
    </div>
  </div>`).join('') || '<div style="color:#888;font-size:13px">No feeds added yet.</div>';
}

async function addYouTubeChannel() {
  const input = document.getElementById('yt-channel-input').value.trim();
  const backfill = parseInt(document.getElementById('yt-backfill').value) || 0;
  if (!input) return;

  const btn = document.getElementById('yt-add-btn');
  btn.textContent = 'Resolving...';
  btn.disabled = true;

  try {
    const r = await fetch('/api/feeds/youtube', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ input, backfill })
    });
    const d = await r.json();
    if (d.error) throw new Error(d.error);
    document.getElementById('yt-channel-input').value = '';
    document.getElementById('yt-backfill').value = '0';
    toast('YouTube channel subscribed');
    loadFeeds(); loadEpisodes();
  } catch(e) {
    alert('Error: ' + e.message);
  } finally {
    btn.textContent = 'Subscribe';
    btn.disabled = false;
  }
}

async function addFeed() {
  const name = document.getElementById('feed-name').value.trim();
  const url = document.getElementById('feed-url').value.trim();
  if (!url) return;
  await fetch('/api/feeds', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ name: name || undefined, url })
  });
  document.getElementById('feed-name').value = '';
  document.getElementById('feed-url').value = '';
  toast('Feed added and polled');
  loadFeeds(); loadEpisodes();
}

async function patchFeedMeta(id, field, value) {
  await fetch('/api/feeds/' + id + '/meta', {
    method: 'PATCH',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ [field]: value })
  });
}

async function deleteFeed(id) {
  await fetch(`/api/feeds/${id}`, { method: 'DELETE' });
  loadFeeds();
}

async function pollAll() {
  toast('Polling all feeds...');
  const data = await fetch('/api/feeds/poll', { method: 'POST' }).then(r => r.json());
  toast(`Poll complete: ${data.newEpisodes} new episodes`);
  loadEpisodes();
}

// --- Tags ---
async function loadTags() {
  const data = await fetch('/api/tags').then(r => r.json());
  const list = document.getElementById('tags-list');
  list.innerHTML = data.map(t => `<div class="tag-pill">
    ${esc(t.text)}
    <button onclick="deleteTag(${t.id})">&times;</button>
  </div>`).join('') || '<div style="color:#888;font-size:13px">No tags.</div>';
}

async function addTag() {
  const text = document.getElementById('tag-text').value.trim();
  if (!text) return;
  await fetch('/api/tags', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ text })
  });
  document.getElementById('tag-text').value = '';
  loadTags();
}

async function deleteTag(id) {
  await fetch(`/api/tags/${id}`, { method: 'DELETE' });
  loadTags();
}

// --- Suggested Tags ---
async function fetchSuggestedTags(summaryId) {
  const r = await fetch('/api/summaries/' + summaryId + '/suggested-tags');
  const d = await r.json();
  return d.suggested || [];
}

async function addInterestTag(text, btn) {
  btn.disabled = true;
  btn.textContent = '...';
  try {
    await fetch('/api/tags', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ text })
    });
    btn.textContent = 'Added';
    btn.parentElement.style.opacity = '0.5';
  } catch (e) {
    btn.textContent = 'Error';
    btn.disabled = false;
  }
}

async function renderSuggestedTags(summaryId, container) {
  const tags = await fetchSuggestedTags(summaryId);
  if (!tags.length) return;
  const wrap = document.createElement('div');
  wrap.className = 'suggested-tags';
  wrap.innerHTML = '<div class="suggested-tags-label">SUGGESTED INTEREST TAGS</div>' +
    tags.map(t => `<span class="suggested-tag">${esc(t)} <button onclick="addInterestTag('${t.replace(/'/g,"\\'")}', this)">Add</button></span>`).join('');
  container.appendChild(wrap);
}

// --- Helpers ---
function esc(s) { if (!s) return ''; const d = document.createElement('div'); d.textContent = s; return d.innerHTML; }
function fmtDate(d) { if (!d) return '—'; try { return new Date(d).toLocaleDateString('en-GB', { day:'numeric', month:'short', year:'numeric' }); } catch(_) { return d; } }
function toast(msg) {
  const t = document.createElement('div');
  t.className = 'toast';
  t.textContent = msg;
  document.body.appendChild(t);
  setTimeout(() => t.remove(), 3000);
}

// --- Auto-refresh ---
setInterval(() => { if (currentTab === 'queue') loadEpisodes(); }, 30000);

// --- Init ---
loadEpisodes();
</script>
</body>
</html>
